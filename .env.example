# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# AWS credentials for S3 Vectors
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 Vectors bucket/index names
S3V_BUCKET_NAME=honeyjar-vectors
S3V_INDEX_NAME=articles

# NewsAPI (optional — only needed for live ingestion)
NEWSAPI_KEY=

# Server
PORT=3001
